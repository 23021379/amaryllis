      "description": "Click the 'Public Access' link to navigate to the planning application search portal, as the current page is a landing page."
    },
    {
      "command": "WAIT_FOR_NAVIGATION",
      "params": {},
      "description": "Wait for the browser to navigate to the planning portal URL."
    },
    {
      "command": "CLICK_ELEMENT",
      "params": {
        "selector": "a:has-text(\"Accept\")"
      },
      "description": "Dismiss any 'Accept' or 'Agree' cookie or disclaimer modal that might appear on the planning portal, adhering to the Idox disclaimer gate pattern."
    },
    {
      "command": "FILL_INPUT",
      "params": {
        "selector": "input#simpleSearchString",
        "value": "{{REFERENCE_ID}}"
      },
      "description": "Fill the primary search input field (common for Idox simple searches) with the planning application reference ID."
    },
    {
      "command": "CLICK_ELEMENT",
      "params": {
        "selector": "input[value=\"Search\"]"
      },
      "description": "Click the 'Search' button to submit the application query."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "#searchresults, #applicationDetails, h1:has-text('Application Summary')"
      },
      "description": "Wait for the search results list, a direct application details page, or a summary header to become visible, indicating a successful search outcome."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "#tab_summary"
      },
      "description": "Wait for Application Details modal/view to appear."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "a#tab_documents"
      },
      "description": "Wait for detail page."
    },
    {
      "command": "CLICK_ELEMENT",
      "params": {
        "selector": "a#tab_documents"
      },
      "description": "Open Documents tab."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "p.associateddocument a"
      },
      "description": "Wait for 'View Documents' link/button."
    },
    {
      "command": "CLICK_ELEMENT",
      "params": {
        "selector": "p.associateddocument a"
      },
      "description": "Click 'View Documents' link."
    },
    {
      "command": "WAIT_FOR_SELECTOR",

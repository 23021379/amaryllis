{
  "domain": "www.bolton.gov.uk",
  "plan_version": "3.0",
  "last_updated": "2026-03-11T18:01:57.898741Z",
  "instructions": [
    {
      "command": "GOTO_URL",
      "params": {
        "url": "https://paplanning.bolton.gov.uk/online-applications/search.do?action=simple&searchType=Application"
      },
      "description": "Navigate to the search page."
    },
    {
      "command": "FILL_INPUT",
      "params": {
        "selector": "#simpleSearchString",
        "value": "{{REFERENCE_ID}}"
      },
      "description": "Enter the Reference ID into the search field."
    },
    {
      "command": "CLICK_ELEMENT",
      "params": {
        "selector": "input.button.primary"
      },
      "description": "Click the search button to submit the form."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "#searchresults, .search-results, h1:has-text('Summary'), #simpleDetailsTable",
        "state": "visible"
      },
      "description": "Wait for the search results page or individual application details to load."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "#simpleDetailsTable"
      },
      "description": "Wait for Application Details modal/view to appear."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "a#tab_documents"
      },
      "description": "Wait for detail page."
    },
    {
      "command": "CLICK_ELEMENT",
      "params": {
        "selector": "a#tab_documents"
      },
      "description": "Open Documents tab."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "p.associateddocument > a"
      },
      "description": "Wait for 'View Documents' link/button."
    },
    {
      "command": "CLICK_ELEMENT",
      "params": {
        "selector": "p.associateddocument > a"
      },
      "description": "Click 'View Documents' link."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "table#Documents > tbody > tr:not(:has(th))"
      },
      "description": "Wait for documents table."
    }
  ],
  "results_page_processing": {
    "listing_container_selector": "#simpleDetailsTable",
    "listing_link_blueprint": {

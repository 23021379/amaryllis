  "instructions": [
    {
      "command": "GOTO_URL",
      "params": {
        "url": "https://abcportal.ashford.gov.uk/pr/s/register-view?c__r=Arcus_BE_Public_Register"
      },
      "description": "Navigate to the search page."
    },
    {
      "command": "FILL_INPUT",
      "params": {
        "selector": "arcuscommunity-pr_search input[type=\"text\"], arcuscommunity-pr_search input.slds-input",
        "value": "{{REFERENCE_ID}}"
      },
      "description": "Fill the primary text input field within the planning search component with the application reference ID."
    },
    {
      "command": "CLICK_ELEMENT",
      "params": {
        "selector": "arcuscommunity-pr_search button:has-text(\"Search\"), arcuscommunity-pr_search button[type=\"submit\"]"
      },
      "description": "Click the 'Search' button to submit the query. This accounts for a text button or a submit type button within the search component."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "div[class*=\"search-results\"], div[class*=\"result-list\"], article[class*=\"application-details\"], h1:has-text(\"Application Details\"), h2:has-text(\"Search Results\")"
      },
      "description": "Wait for elements indicating search results or the application details page to become visible."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "div.slds-form.slds-box[arcuscommunity-pr_articles_pr_articles] >> label:has-text(\"Application Reference\") + div.slds-form-element__control lightning-formatted-url a"
      },
      "description": "Wait for search results."
    },
    {
      "command": "CLICK_ELEMENT",
      "params": {
        "selector": "div.slds-form.slds-box[arcuscommunity-pr_articles_pr_articles] >> label:has-text(\"Application Reference\") + div.slds-form-element__control lightning-formatted-url a"
      },
      "description": "Click the search result to view details."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "a[role=\"tab\"]:has-text(\"Plans And Documents\")"
      },
      "description": "Wait for detail page."
    },
    {
      "command": "CLICK_ELEMENT",
      "params": {
        "selector": "a[role=\"tab\"]:has-text(\"Plans And Documents\")"
      },
      "description": "Open Documents tab."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "table.pr-table > tbody > tr.pr-table__row"
      },
      "description": "Wait for documents table."
    }
  ],

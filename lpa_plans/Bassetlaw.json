{
  "domain": "www.bassetlaw.gov.uk",
  "plan_version": "3.0",
  "last_updated": "2026-03-11T15:48:06.713438Z",
  "instructions": [
    {
      "command": "GOTO_URL",
      "params": {
        "url": "https://publicaccess.bassetlaw.gov.uk/online-applications/search.do?action=simple&searchType=Application"
      },
      "description": "Navigate to the Simple Search page for Planning Applications."
    },
    {
      "command": "FILL_INPUT",
      "params": {
        "selector": "input#simpleSearchString",
        "value": "{{REFERENCE_ID}}"
      },
      "description": "Fill the main search input with the placeholder reference ID."
    },
    {
      "command": "CLICK_ELEMENT",
      "params": {
        "selector": "input[type='submit'][value='Search']"
      },
      "description": "Submit the search by clicking the 'Search' button."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "table.results, div.search-results, h1:has-text('Application Details')"
      },
      "description": "Wait for the search results list or direct application details page to load."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "li.searchresult >> a.summaryLink",
        "timeout": 3000
      },
      "description": "Wait for search results."
    },
    {
      "command": "TRY_CLICK_ELEMENT",
      "params": {
        "selector": "li.searchresult >> a.summaryLink",
        "timeout": 3000
      },
      "description": "Click the search result to view details."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "a#tab_documents"
      },
      "description": "Wait for detail page."
    },
    {
      "command": "CLICK_ELEMENT",
      "params": {
        "selector": "a#tab_documents"
      },
      "description": "Open Documents tab."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "p.associateddocument > a"
      },
      "description": "Wait for 'View Documents' link/button."
    },
    {
      "command": "CLICK_ELEMENT",
      "params": {
        "selector": "p.associateddocument > a"
      },
      "description": "Click 'View Documents' link."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "table#Documents tbody tr:has(td)"
      },
      "description": "Wait for documents table."
    }
  ],

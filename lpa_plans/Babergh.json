{
  "domain": "babergh.gov.uk",
  "plan_version": "3.0",
  "last_updated": "2026-03-11T15:28:59.559084Z",
  "instructions": [
    {
      "command": "GOTO_URL",
      "params": {
        "url": "https://planning.baberghmidsuffolk.gov.uk/online-applications/"
      },
      "description": "Navigate to the search page."
    },
    {
      "command": "FILL_INPUT",
      "params": {
        "selector": "input#simpleSearchString",
        "value": "{{REFERENCE_ID}}"
      },
      "description": "Enter the application reference ID into the simple search input field."
    },
    {
      "command": "CLICK_ELEMENT",
      "params": {
        "selector": "input[type=\"submit\"][value=\"Search\"]"
      },
      "description": "Click the 'Search' button to submit the query."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "table.resultsTable, h1:has-text(\"Application Summary\"), h2:has-text(\"Application Details\"), div.searchresults, div#application_details"
      },
      "description": "Wait for the search results table, application summary heading, or application details container to appear, indicating the search was successful."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "h1:has-text('Application Summary')"
      },
      "description": "Wait for Application Details modal/view to appear."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "a#tab_documents"
      },
      "description": "Wait for detail page."
    },
    {
      "command": "CLICK_ELEMENT",
      "params": {
        "selector": "a#tab_documents"
      },
      "description": "Open Documents tab."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "p.associateddocument > a"
      },
      "description": "Wait for 'View Documents' link/button."
    },
    {
      "command": "CLICK_ELEMENT",
      "params": {
        "selector": "p.associateddocument > a"
      },
      "description": "Click 'View Documents' link."
    },
    {
      "command": "WAIT_FOR_SELECTOR",
      "params": {
        "selector": "table#Documents > tbody > tr"
      },
      "description": "Wait for documents table."
    }
  ],
